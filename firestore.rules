rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'MANAGEMENT') ||
        request.auth.token.email == 'scienceolympiad@semesta.sch.id'
      );
    }
    
    // Auth helpers
    function isSignedIn() { return request.auth != null; }
    // Asumsikan admin dikelola pada document terpisah /users/{uid} dengan atribut role
    function isAdmin() { 
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN'; 
    }
    function isManagement() { 
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'MANAGEMENT') ||
        request.auth.token.email == 'scienceolympiad@semesta.sch.id'
      ); 
    }

    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Users Collection
    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'name']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 200 &&
             data.name is string && data.name.size() <= 200 &&
             data.role in ['ADMIN', 'MANAGEMENT', 'STUDENT'];
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidUserProfile(incoming()) && incoming().uid == request.auth.uid && (incoming().role == 'STUDENT' || (incoming().role == 'MANAGEMENT' && request.auth.token.email == 'scienceolympiad@semesta.sch.id'));
      allow update: if isSignedIn() && (
        isAdmin() || 
        (request.auth.uid == userId && isValidUserProfile(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'updatedAt']) && incoming().uid == existing().uid)
      );
    }
    
    // Students Collection
    function isValidStudent(data) {
      return data.keys().hasAll(['userId', 'fullName', 'createdAt', 'updatedAt']) &&
             data.userId is string && data.userId.size() > 0 &&
             data.fullName is string && data.fullName.size() <= 200 &&
             data.createdAt is number &&
             data.updatedAt is number;
    }

    match /students/{studentId} {
      // Students can read all students for Leaderboard
      allow read: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(studentId) && isValidStudent(incoming()) && incoming().userId == request.auth.uid;
      // Allow student to update their data, preventing change of userId constraint
      allow update: if isSignedIn() && (isAdmin() || isManagement() || (existing().userId == request.auth.uid && incoming().userId == existing().userId && isValidStudent(incoming())));
      allow delete: if isAdmin();
    }

    // Competitions Collection
    function isValidCompetition(data) {
      return data.keys().hasAll(['title', 'status', 'type', 'field', 'registrationDeadline']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.status in ['OPEN', 'CLOSED'] &&
             data.type in ['Daring', 'Luring', 'Hybrid'] &&
             data.field is list && data.field.size() > 0 &&
             data.registrationDeadline is number;
    }

    match /competitions/{compId} {
      allow read: if true;
      allow list: if true;
      allow create: if isSignedIn() && isValidId(compId) && isValidCompetition(incoming());
      allow update: if isValidCompetition(incoming()) && (
        isAdmin() || isManagement() || 
        (existing().proposedByUserId == request.auth.uid && existing().isApproved == false)
      );
      allow delete: if (isAdmin() || isManagement());
    }

    // Registrations Collection
    function isValidRegistration(data) {
      return data.keys().hasAll(['studentId', 'competitionId', 'status']) &&
             data.studentId is string && data.studentId.size() > 0 &&
             data.competitionId is string && data.competitionId.size() > 0 &&
             data.status in ['PENDING', 'APPROVED', 'REJECTED'];
    }

    match /registrations/{regId} {
      allow read: if true;
      allow list: if true;
      allow create: if isSignedIn() && isValidId(regId) && isValidRegistration(incoming()) && incoming().studentId == request.auth.uid;
      allow update: if isSignedIn() && (
        isAdmin() || isManagement() || 
        (request.auth.uid == existing().studentId && incoming().studentId == existing().studentId && incoming().status == existing().status)
      ) && isValidRegistration(incoming());
      allow delete: if isAdmin() || isManagement();
    }

    // Achievements Collection
    match /achievements/{achId} {
      allow read: if isSignedIn();
      allow list: if isSignedIn();
      allow create, update, delete: if isAdmin() || isManagement();
    }

    // OSN
    match /osn/{osnId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isManagement();
    }

    match /osn_announcements/{id} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin() || isManagement();
    }

    match /osn_banksoal/{id} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin() || isManagement();
    }

    // Guidance Logs
    function isValidGuidanceLog(data) {
      return data.keys().hasAll(['studentId', 'date', 'academicSubject', 'studyProgress', 'mood', 'createdAt']) &&
             data.studentId is string && data.studentId.size() > 0 &&
             data.date is number &&
             data.academicSubject is string && data.academicSubject.size() <= 200 &&
             data.studyProgress is string && data.studyProgress.size() <= 2000 &&
             data.mood in ['GREAT', 'GOOD', 'NEUTRAL', 'BAD', 'TERRIBLE'] &&
             data.createdAt is number;
    }

    match /guidanceLogs/{logId} {
      allow read: if isSignedIn() && (isAdmin() || isManagement() || existing().studentId == request.auth.uid);
      allow list: if isSignedIn() && (isAdmin() || isManagement() || resource.data.studentId == request.auth.uid);
      allow create: if isSignedIn() && isValidId(logId) && isValidGuidanceLog(incoming()) && incoming().studentId == request.auth.uid;
      allow update: if isManagement() && isValidGuidanceLog(incoming()) && incoming().studentId == existing().studentId;
      allow delete: if isManagement();
    }
    // Chat Collection
    function isValidChat(data) {
      return data.keys().hasAll(['roomId', 'senderId', 'senderName', 'senderRole', 'text', 'createdAt']) &&
             data.roomId is string && data.roomId.size() > 0 && data.roomId.size() <= 100 &&
             data.senderId is string && data.senderId.size() > 0 &&
             data.senderName is string && data.senderName.size() <= 200 &&
             data.senderRole in ['STUDENT', 'ADMIN', 'MANAGEMENT'] &&
             data.text is string && data.text.size() <= 5000 &&
             data.createdAt is number &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 2000));
    }

    match /chats/{chatId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(chatId) && isValidChat(incoming()) && incoming().senderId == request.auth.uid;
      allow delete: if isAdmin() || isManagement();
      allow update: if false;
    }
  }
}
